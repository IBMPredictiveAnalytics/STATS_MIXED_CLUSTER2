#, c-format
msgid "Output variables or root: %s: "
msgstr "Variables de salida o raíz: %s: "

#: STATS_MIXED_CLUSTER2.R:378
#, c-format
msgid "Integer variables must have a scale measurement level: %s"
msgstr "Las variables enteras deben tener un nivel de medición de escala: %s"

#: STATS_MIXED_CLUSTER2.R:388
#, c-format
msgid ""
"A nonnumeric or negative value was found in an integer variable.  Set to missing:\n"
" %s"
msgstr ""
"Se ha encontrado un valor no numérico o negativo en una variable de tipo entero.  Configurar como perdido:\n"
" %s"

#: STATS_MIXED_CLUSTER2.R:412
msgid "Estimation or new data dataset is required"
msgstr "Se requiere una estimación o un nuevo conjunto de datos."


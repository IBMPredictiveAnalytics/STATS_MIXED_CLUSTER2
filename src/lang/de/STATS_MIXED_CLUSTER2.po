#, c-format
msgid "Integer variables must have a scale measurement level: %s"
msgstr "Ganzzahlige Variablen müssen ein metrisches Messniveau aufweisen: %s"

#: STATS_MIXED_CLUSTER2.R:388
#, c-format
msgid ""
"A nonnumeric or negative value was found in an integer variable.  Set to missing:\n"
" %s"
msgstr ""
"In einer ganzzahligen Variablen wurde ein nicht-numerischer oder negativer Wert gefunden.  Als fehlend festgelegt:\n"
" %s"

